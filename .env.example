# ==========================================================
# LocalMind AI — root environment example
# Copy to .env and adjust as needed. Everything runs locally.
# ==========================================================

# ---------- Ollama (local AI engine) ----------
# Host URL of your running Ollama server.
# Local dev default: http://localhost:11434
# Docker compose:    http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# Default models (must be pulled: `ollama pull qwen2.5:3b` / `ollama pull all-minilm`)
LOCALMIND_CHAT_MODEL=qwen2.5:3b
LOCALMIND_EMBEDDING_MODEL=all-minilm

# ---------- Backend (FastAPI) ----------
# Bind host/port for uvicorn
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# SQLite database URL
DATABASE_URL=sqlite:///./database/localmind.db

# ChromaDB persistent directory
CHROMA_DIR=./vectorstore

# Filesystem storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
LOG_DIR=./logs

# CORS origin for the frontend
CORS_ORIGIN=http://localhost:3000

# Optional engines
OCR_ENGINE=tesseract
SPEECH_ENGINE=whisper

# ---------- Frontend (Next.js) ----------
# Base URL the browser uses to reach the backend
NEXT_PUBLIC_API_BASE=http://localhost:8000
